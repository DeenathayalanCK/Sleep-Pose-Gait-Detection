# ── Video source ───────────────────────────────────────────────────────────────
# Recorded file:  data/videos/test1.mp4
# RTSP stream:    rtsp://user:pass@192.168.1.100:554/stream
VIDEO_SOURCE=data/videos/test1.mp4
CAMERA_ID=camera_1

# ── Frame resolution ───────────────────────────────────────────────────────────
FRAME_WIDTH=640
FRAME_HEIGHT=480

# ── Storage ────────────────────────────────────────────────────────────────────
DATABASE_PATH=data/database/events.db
SNAPSHOT_DIR=data/snapshots

# ── LLM (optional) ────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3:8b

# ── Eye / EAR (secondary signal — frontal face only) ──────────────────────────
EAR_THRESHOLD=0.25

# ── Sleep detection ────────────────────────────────────────────────────────────
# Seconds of zero motion → SLEEPING (any posture: reclined, head-on-desk, etc.)
SLEEP_SECONDS=10.0

# Seconds of low motion → DROWSY (early warning)
DROWSY_SECONDS=5.0

# If clearly reclined, trigger SLEEPING after this shorter window
SLEEP_SECONDS_RECLINED=7.0

# ── Posture / recline ──────────────────────────────────────────────────────────
# Body X-span ratio above which posture is "clearly reclined" (0.0–1.0)
# Top-down CCTV: 0.58–0.65 | Side-mounted: try 0.45–0.55
RECLINE_THRESHOLD=0.60

# Ratio below which recline signal is ignored entirely
RECLINE_MIN=0.50

# ── Motion sensitivity ─────────────────────────────────────────────────────────
# Mean per-pixel change below which frame counts as "no motion"
# Static indoor office: 0.8–1.5 | Noisy/outdoor: 2.0–4.0
MOTION_THRESHOLD=1.2

# ── Alerts ────────────────────────────────────────────────────────────────────
# Seconds between repeated alerts for the same sleep episode
ALERT_COOLDOWN_SECONDS=30.0

# ── MediaPipe pose confidence ──────────────────────────────────────────────────
# Lower for distant/angled cameras | Raise for close high-quality feeds
POSE_DETECTION_CONFIDENCE=0.45
POSE_TRACKING_CONFIDENCE=0.45
POSE_LANDMARK_MIN_VISIBILITY=0.35

# ── Smoothing ──────────────────────────────────────────────────────────────────
# Frames to average recline ratio over (higher = smoother, slower to react)
RECLINE_SMOOTH_FRAMES=8

# ── Nod detection ─────────────────────────────────────────────────────────────
NOD_THRESHOLD=0.03

# ── Email alerts (optional) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_TO=

# ── Telegram alerts (optional) ────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=