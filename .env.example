# ── Video source ───────────────────────────────────────────────────────────────
VIDEO_SOURCE=data/videos/test1.mp4
CAMERA_ID=second_floor_middle

# ── Frame resolution ───────────────────────────────────────────────────────────
FRAME_WIDTH=640
FRAME_HEIGHT=480

# ── Storage ────────────────────────────────────────────────────────────────────
DATABASE_PATH=data/database/events.db
SNAPSHOT_DIR=data/snapshots

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# ── EAR (secondary) ───────────────────────────────────────────────────────────
EAR_THRESHOLD=0.25

# ── Sleep detection — tuned for busy side-mounted office camera ───────────────
# Longer windows because people naturally sit still in an office.
SLEEP_SECONDS=15.0
DROWSY_SECONDS=8.0
SLEEP_SECONDS_RECLINED=12.0

# ── Posture / recline — side-mounted camera geometry ──────────────────────────
# Side view: seated person's body ratio is ~0.4–0.5, NOT 0.6 like top-down.
RECLINE_THRESHOLD=0.45
RECLINE_MIN=0.38

# ── Motion — higher for busy office (background people always moving) ─────────
MOTION_THRESHOLD=2.5

# ── Alert cooldown ────────────────────────────────────────────────────────────
ALERT_COOLDOWN_SECONDS=30.0

# ── MediaPipe — lower confidence for crowded/occluded scene ───────────────────
POSE_DETECTION_CONFIDENCE=0.40
POSE_TRACKING_CONFIDENCE=0.40
POSE_LANDMARK_MIN_VISIBILITY=0.30

# ── Recline smoothing ──────────────────────────────────────────────────────────
RECLINE_SMOOTH_FRAMES=8

# ── Nod detection ─────────────────────────────────────────────────────────────
NOD_THRESHOLD=0.03

# ── YOLO + ByteTrack multi-person tracking ─────────────────────────────────────
# yolov8n.pt = nano (fastest, CPU). Use yolov8s.pt for better accuracy.
YOLO_MODEL=yolov8n.pt
# Lower conf for crowded scene — catches partially occluded people.
YOLO_CONF=0.30
YOLO_IOU=0.45

# Max persons to run full MediaPipe skeleton on per frame (sorted by size).
# Others get bounding box + state tracking only (no skeleton drawing).
MAX_POSE_PERSONS=6

# Seconds before absent track's state is discarded (re-entry window).
TRACK_TIMEOUT_SECONDS=30.0
TRACK_REENTRY_SECONDS=120.0

# ── Posture classification ────────────────────────────────────────────────────
# Higher walk threshold — background motion from other people creates noise.
POSTURE_WALK_MOTION_THRESHOLD=5.0
POSTURE_SIT_Y_RATIO=0.20
POSTURE_STAND_Y_RATIO=0.12

# ── Email alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_TO=

# ── Telegram alerts (optional) ───────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Walk detection (centroid-based, not motion-based) ─────────────────────────
# Pixels of bbox centroid shift per frame to count as movement
WALK_CENTROID_PX=8
# Consecutive frames needed to confirm walking
WALK_CENTROID_FRAMES=4
# Seconds of stillness (not sleeping) before showing IDLE label
INACTIVE_DISPLAY_SECONDS=5.0

# ── Seated knee geometry (side-mounted camera) ────────────────────────────────
# Seated person's knees extend FORWARD — X gap from hips is large
POSTURE_SEATED_KNEE_X_GAP=0.06
# Standing person's knees drop BELOW hips — Y gap from hips is large
POSTURE_STANDING_KNEE_Y_GAP=0.12

# ── Multi-signal fatigue thresholds (auto-calibrated values override these) ───
# Head drop angle (degrees from vertical) — head drooping forward
HEAD_DROP_DROWSY_DEG=40.0
HEAD_DROP_SLEEP_DEG=55.0
# Head lateral tilt (degrees) — head fallen sideways = sleeping
HEAD_TILT_SLEEP_DEG=35.0
# Spine angle (degrees from vertical) — torso tilting
SPINE_DROWSY_DEG=30.0
SPINE_SLEEP_DEG=50.0
# Wrist activity threshold — min wrist movement = person is typing = awake
WRIST_ACTIVE_MIN=0.005
# Signal smoothing window (frames) — prevents flickering
SIGNAL_SMOOTH_FRAMES=10

# ── EAR / PERCLOS — eye closure drowsiness detection ─────────────────────────
# PERCLOS = % of frames with eyes closed in rolling window (clinical standard)
PERCLOS_DROWSY_THRESHOLD=0.15
PERCLOS_SLEEP_THRESHOLD=0.40
PERCLOS_WINDOW_FRAMES=60
EAR_FACE_CONF_MIN=0.50

# ── ReID — appearance-based person re-identification ─────────────────────────
# Cosine similarity threshold to match returning person (0.0–1.0, higher=stricter)
REID_MATCH_THRESHOLD=0.82
# Seconds to remember a person's appearance after they leave frame
REID_GALLERY_TIMEOUT=300.0
# Number of past embeddings to average for matching (more = more stable)
REID_EMB_HISTORY=5
# Update embedding every N frames (reduces CPU overhead)
REID_UPDATE_EVERY_FRAMES=15

# ── Per-person Z-score baseline (adaptive per-individual detection) ────────────
# Standard deviations above personal baseline to trigger drowsy/sleeping
Z_DROWSY_THRESHOLD=2.0
Z_SLEEP_THRESHOLD=3.0
# Awake frames needed to build baseline (~5 min of active work at 0.5fps)
ZSCORE_WARMUP_FRAMES=150
# Minimum std floor in degrees — prevents hair-trigger on very consistent sitters
ZSCORE_MIN_STD=2.0
# Baseline drift rate — 0.02 = very slow, adapts to posture changes over a shift
ZSCORE_EMA_ALPHA=0.02

# ── PostgreSQL (leave blank to use SQLite fallback for local dev) ─────────────
# Docker sets this automatically via docker-compose environment section.
# Only set manually if running outside Docker.
DATABASE_URL=