# Video source (file path or RTSP URL)
VIDEO_SOURCE=data/videos/test.mp4
CAMERA_ID=camera_1

# Detection
EAR_THRESHOLD=0.25
FATIGUE_SECONDS=5

# Frame
FRAME_WIDTH=640
FRAME_HEIGHT=480

# Storage
DATABASE_PATH=data/database/events.db
SNAPSHOT_DIR=data/snapshots

# LLM (optional — set to skip)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Alerts (all optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_TO=

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
